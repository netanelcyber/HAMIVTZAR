{
	"name": "automattic/jetpack-codesniffer",
	"description": "Jetpack Coding Standards. Based on the WordPress Coding Standards, with some additions.",
	"type": "phpcodesniffer-standard",
	"license": "MIT",
	"keywords": [
		"phpcs",
		"codesniffer",
		"standards",
		"jetpack",
		"dev",
		"testing"
	],
	"require": {
		"php": ">=8.2",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"mediawiki/mediawiki-codesniffer": "^51.0",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"sirbrillig/phpcs-variable-analysis": "^2.10",
		"wp-coding-standards/wpcs": "^3.0",
		"automattic/vipwpcs": "^3.0",
		"phpcsstandards/phpcsutils": "^1.0"
	},
	"require-dev": {
		"yoast/phpunit-polyfills": "^4.0.0",
		"automattic/phpunit-select-config": "@dev"
	},
	"autoload": {
		"classmap": [
			"hacks/"
		],
		"psr-4": {
			"Automattic\\Jetpack\\Sniffs\\": "Jetpack/Sniffs",
			"Automattic\\Jetpack\\Codesniffer\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Automattic\\Jetpack\\Codesniffer\\Tests\\": "tests/php/unit/"
		}
	},
	"scripts": {
		"phpunit": [
			"phpunit-select-config phpunit.#.xml.dist --colors=always"
		],
		"test-php": [
			"@composer phpunit",
			"./check-docs.sh"
		],
		"test-php-coverage": "php -dpcov.directory=. ./vendor/bin/phpunit-select-config phpunit.#.xml.dist --coverage-php \"$COVERAGE_DIR/php.cov\""
	},
	"repositories": [
		{
			"type": "path",
			"url": "../*",
			"options": {
				"monorepo": true
			}
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"autotagger": true,
		"mirror-repo": "Automattic/jetpack-codesniffer",
		"changelogger": {
			"link-template": "https://github.com/Automattic/jetpack-codesniffer/compare/v${old}...v${new}"
		},
		"branch-alias": {
			"dev-trunk": "8.0.x-dev"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
