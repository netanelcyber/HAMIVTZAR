{
	"name": "automattic/jetpack-phpcs-filter",
	"description": "A filter for PHP CodeSniffer to add support for .phpcsignore files and per-directory configuration files.",
	"type": "library",
	"license": "MIT",
	"keywords": [
		"phpcs",
		"filter",
		"plugin",
		"phpcsignore",
		"per-directory config",
		"dev",
		"testing"
	],
	"require": {
		"php": ">=7.2",
		"automattic/ignorefile": "@dev",
		"squizlabs/php_codesniffer": "^3.6.1 || ^4.0.0"
	},
	"require-dev": {
		"yoast/phpunit-polyfills": "^4.0.0",
		"automattic/phpunit-select-config": "@dev"
	},
	"autoload": {
		"classmap": [
			"src/"
		]
	},
	"scripts": {
		"phpunit": [
			"phpunit-select-config phpunit.#.xml.dist --colors=always"
		],
		"test-php": "@composer phpunit",
		"test-php-coverage": "php -dpcov.directory=. ./vendor/bin/phpunit-select-config phpunit.#.xml.dist --coverage-php \"$COVERAGE_DIR/php.cov\""
	},
	"repositories": [
		{
			"type": "path",
			"url": "../../packages/*",
			"options": {
				"monorepo": true
			}
		},
		{
			"type": "vcs",
			"url": "https://github.com/Automattic/PHP_CodeSniffer"
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"branch-alias": {
			"dev-trunk": "4.0.x-dev"
		}
	}
}
