{
	"name": "@automattic/jetpack-publicize",
	"version": "0.83.5",
	"private": true,
	"description": "Publicize makes it easy to share your site’s posts on several social media networks automatically when you publish a new post.",
	"homepage": "https://github.com/Automattic/jetpack/tree/HEAD/projects/packages/publicize/#readme",
	"bugs": {
		"url": "https://github.com/Automattic/jetpack/labels/[Package] Publicize"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Automattic/jetpack.git",
		"directory": "projects/packages/publicize"
	},
	"license": "GPL-2.0-or-later",
	"author": "Automattic",
	"exports": {
		"./link-preview": {
			"jetpack:src": "./_inc/exports/link-preview/index.ts",
			"default": "./_inc/exports/link-preview/index.ts"
		}
	},
	"scripts": {
		"build": "pnpm run clean && concurrently 'pnpm:build-client' 'pnpm:build:wp-build' && pnpm run build:boot-asset",
		"build:boot-asset": "provide-boot-asset-file",
		"build:strip-unminified-prod": "strip-unminified-prod",
		"build:wp-build": "wp-build",
		"build-client": "webpack",
		"build-production": "pnpm run clean && concurrently 'pnpm:build-production-js' 'pnpm:build:wp-build' && pnpm run build:strip-unminified-prod && pnpm run build:boot-asset && pnpm run validate",
		"build-production-js": "NODE_ENV=production BABEL_ENV=production pnpm run build-client",
		"clean": "rm -rf build/",
		"test": "TZ=UTC jest",
		"test-coverage": "pnpm run test --coverage",
		"typecheck": "tsgo --noEmit",
		"validate": "pnpm exec validate-es build/",
		"watch": "concurrently 'pnpm:build-client --watch' 'pnpm:watch:wp-build'",
		"watch:hot": "pnpm run clean && webpack serve",
		"watch:wp-build": "wp-build --watch"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"dependencies": {
		"@automattic/charts": "workspace:*",
		"@automattic/jetpack-ai-client": "workspace:*",
		"@automattic/jetpack-analytics": "workspace:*",
		"@automattic/jetpack-components": "workspace:*",
		"@automattic/jetpack-connection": "workspace:*",
		"@automattic/jetpack-script-data": "workspace:*",
		"@automattic/jetpack-shared-extension-utils": "workspace:*",
		"@automattic/number-formatters": "workspace:*",
		"@automattic/popup-monitor": "1.0.2",
		"@automattic/social-previews": "workspace:*",
		"@automattic/ui": "1.0.2",
		"@tanstack/react-query": "5.90.8",
		"@wordpress/admin-ui": "2.5.0",
		"@wordpress/annotations": "3.50.0",
		"@wordpress/api-fetch": "7.50.0",
		"@wordpress/base-styles": "10.2.0",
		"@wordpress/block-editor": "15.23.0",
		"@wordpress/blocks": "15.23.0",
		"@wordpress/components": "36.1.0",
		"@wordpress/compose": "8.3.0",
		"@wordpress/core-data": "7.50.0",
		"@wordpress/data": "10.50.0",
		"@wordpress/dataviews": "17.1.0",
		"@wordpress/date": "5.50.0",
		"@wordpress/edit-post": "8.50.0",
		"@wordpress/editor": "14.50.0",
		"@wordpress/element": "8.2.0",
		"@wordpress/hooks": "4.50.0",
		"@wordpress/html-entities": "4.50.0",
		"@wordpress/i18n": "6.23.0",
		"@wordpress/icons": "15.1.0",
		"@wordpress/interface": "9.35.0",
		"@wordpress/media-utils": "5.50.0",
		"@wordpress/notices": "5.50.0",
		"@wordpress/plugins": "7.50.0",
		"@wordpress/preferences": "4.50.0",
		"@wordpress/route": "0.16.0",
		"@wordpress/theme": "0.17.0",
		"@wordpress/ui": "0.17.0",
		"@wordpress/url": "4.50.0",
		"clsx": "2.1.1",
		"jquery": "3.7.1",
		"prop-types": "15.8.1",
		"social-logos": "workspace:*"
	},
	"devDependencies": {
		"@automattic/babel-plugin-replace-textdomain": "workspace:*",
		"@automattic/calypso-color-schemes": "4.0.0",
		"@automattic/color-studio": "4.1.0",
		"@automattic/jetpack-base-styles": "workspace:*",
		"@automattic/jetpack-webpack-config": "workspace:*",
		"@automattic/jetpack-wp-build-polyfills": "workspace:*",
		"@babel/core": "7.29.7",
		"@babel/runtime": "7.29.7",
		"@csstools/postcss-global-data": "4.0.0",
		"@storybook/react": "10.4.6",
		"@testing-library/dom": "10.4.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/jest": "30.0.0",
		"@types/react": "18.3.28",
		"@typescript/native-preview": "7.0.0-dev.20260707.2",
		"@wordpress/browserslist-config": "6.50.0",
		"@wordpress/build": "0.18.0",
		"autoprefixer": "10.4.20",
		"babel-jest": "30.4.1",
		"browserslist": "^4.24.0",
		"concurrently": "10.0.3",
		"copy-webpack-plugin": "14.0.0",
		"jest": "30.4.2",
		"postcss": "8.5.14",
		"postcss-custom-properties": "12.1.11",
		"postcss-loader": "8.2.0",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"sass-embedded": "1.97.3",
		"sass-loader": "16.0.5",
		"storybook": "10.4.6",
		"typescript": "6.0.3",
		"webpack": "5.107.2",
		"webpack-cli": "6.0.1",
		"webpack-dev-server": "5.2.5"
	},
	"wpPlugin": {
		"name": "jetpack_social",
		"scriptGlobal": "jetpackSocial",
		"packageNamespace": "jetpack-social",
		"handlePrefix": "jetpack-social",
		"pages": [
			"jetpack-social-dashboard"
		]
	}
}
