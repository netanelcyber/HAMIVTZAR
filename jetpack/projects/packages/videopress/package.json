{
	"name": "@automattic/jetpack-videopress",
	"version": "0.40.0",
	"private": true,
	"description": "VideoPress package",
	"homepage": "https://github.com/Automattic/jetpack/tree/HEAD/projects/packages/videopress/#readme",
	"bugs": {
		"url": "https://github.com/Automattic/jetpack/labels/[Package] VideoPress"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Automattic/jetpack.git",
		"directory": "projects/packages/videopress"
	},
	"license": "GPL-2.0-or-later",
	"author": "Automattic",
	"scripts": {
		"build": "pnpm run clean && pnpm run build-client && pnpm run build:wp-build && pnpm run build:boot-asset",
		"build:boot-asset": "provide-boot-asset-file",
		"build:strip-unminified-prod": "strip-unminified-prod",
		"build:wp-build": "wp-build",
		"build-client": "webpack",
		"build-production": "NODE_ENV=production BABEL_ENV=production pnpm run build && pnpm run build:strip-unminified-prod",
		"clean": "rm -rf build/",
		"test": "jest",
		"test-coverage": "pnpm run test --coverage",
		"typecheck": "tsgo --noEmit",
		"validate": "pnpm exec validate-es build/",
		"watch": "concurrently 'pnpm:build-client --watch' 'pnpm:watch:wp-build'",
		"watch:wp-build": "wp-build --watch"
	},
	"dependencies": {
		"@automattic/charts": "workspace:*",
