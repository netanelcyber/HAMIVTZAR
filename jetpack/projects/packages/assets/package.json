{
	"private": true,
	"scripts": {
		"build": "pnpm run clean && pnpm run build-js",
		"build-js": "webpack",
		"build-production": "pnpm run clean && pnpm run build-production-js && pnpm run validate",
		"build-production-js": "NODE_ENV=production BABEL_ENV=production pnpm run build-js",
		"clean": "rm -rf build",
		"test": "jest --config=tests/jest.config.cjs",
		"test-coverage": "pnpm run test --coverage",
		"validate": "pnpm exec validate-es build/"
	},
	"browserslist": "extends @wordpress/browserslist-config",
	"dependencies": {
		"@automattic/jetpack-script-data": "workspace:*",
		"@automattic/jetpack-shared-stores": "workspace:*",
		"@wordpress/i18n": "6.23.0",
		"react": "18.3.1"
	},
	"devDependencies": {
		"@automattic/jetpack-webpack-config": "workspace:*",
		"@wordpress/browserslist-config": "6.50.0",
		"concurrently": "10.0.3",
		"jest": "30.4.2",
		"md5-es": "1.8.2",
		"webpack": "5.107.2",
		"webpack-cli": "6.0.1"
	}
}
