{
	"private": true,
	"description": "Package for Jetpack Search products",
	"homepage": "https://github.com/Automattic/jetpack/tree/HEAD/projects/packages/search/#readme",
	"bugs": {
		"url": "https://github.com/Automattic/jetpack/labels/[Package] Search"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Automattic/jetpack",
		"directory": "projects/packages/search"
	},
	"license": "GPL-2.0-or-later",
	"author": "Automattic",
	"main": "main.js",
	"directories": {
		"test": "tests"
	},
	"scripts": {
		"build": "pnpm run clean && pnpm run build-instant && pnpm run build-customberg && pnpm run build-dashboard && pnpm run build-inline && pnpm run build-blocks && pnpm run build-blocks-editor",
		"build-blocks": "webpack --config ./tools/webpack.blocks.config.js",
		"build-blocks-editor": "webpack --config ./tools/webpack.blocks-editor.config.js",
		"build-customberg": "webpack --config ./tools/webpack.customberg.config.js",
		"build-dashboard": "webpack --config ./tools/webpack.dashboard.config.js",
		"build-development": "NODE_ENV=development BABEL_ENV=development pnpm run build",
		"build-inline": "webpack --config ./tools/webpack.inline.config.js",
		"build-instant": "webpack --config ./tools/webpack.instant.config.js",
		"build-production": "NODE_ENV=production BABEL_ENV=production pnpm run build && pnpm run validate",
		"clean": "rm -rf build/",
		"storybook": "cd ../../js-packages/storybook && pnpm run storybook:dev",
		"test": "concurrently 'pnpm:test-scripts' 'pnpm:test-url-tests' 'pnpm:test-size'",
		"test-coverage": "pnpm:test-scripts --coverage && pnpm:test-url-tests --coverage",
		"test-scripts": "jest --passWithNoTests",
		"test-size": "NODE_ENV=production BABEL_ENV=production pnpm run build-instant && NODE_ENV=production BABEL_ENV=production pnpm run build-blocks && size-limit",
		"test-url-tests": "jest --config=jest.url-tests.config.js --passWithNoTests",
		"validate": "pnpm exec validate-es --no-error-on-unmatched-pattern build/",
		"watch": "concurrently 'pnpm:build-instant --watch' 'pnpm:build-customberg --watch' 'pnpm:build-dashboard --watch' 'pnpm:build-inline --watch' 'pnpm:build-blocks --watch' 'pnpm:build-blocks-editor --watch'"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"dependencies": {
		"@automattic/color-studio": "4.1.0",
		"@automattic/jetpack-analytics": "workspace:*",
		"@automattic/jetpack-api": "workspace:*",
		"@automattic/jetpack-base-styles": "workspace:*",
		"@automattic/jetpack-components": "workspace:*",
		"@automattic/jetpack-connection": "workspace:*",
		"@automattic/jetpack-script-data": "workspace:*",
		"@automattic/jetpack-shared-extension-utils": "workspace:*",
		"@automattic/number-formatters": "workspace:*",
		"@microsoft/fetch-event-source": "2.0.1",
		"@wordpress/api-fetch": "7.50.0",
		"@wordpress/base-styles": "10.2.0",
		"@wordpress/block-editor": "15.23.0",
		"@wordpress/blocks": "15.23.0",
		"@wordpress/components": "36.1.0",
		"@wordpress/core-data": "7.50.0",
		"@wordpress/data": "10.50.0",
		"@wordpress/element": "8.2.0",
		"@wordpress/hooks": "4.50.0",
		"@wordpress/i18n": "6.23.0",
		"@wordpress/icons": "15.1.0",
		"@wordpress/interactivity": "6.50.0",
		"@wordpress/server-side-render": "6.26.0",
		"@wordpress/theme": "0.17.0",
		"@wordpress/ui": "0.17.0",
		"@wordpress/url": "4.50.0",
		"@wordpress/viewport": "6.50.0",
		"clsx": "2.1.1",
		"debounce": "2.2.0",
		"fast-json-stable-stringify": "2.1.0",
		"photon": "4.1.1",
		"preact": "10.28.2",
		"prop-types": "15.8.1",
		"q-flat": "1.0.7",
		"qss": "3.0.0",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"react-redux": "7.2.8",
		"redux": "4.2.1",
		"refx": "3.1.1",
		"strip": "3.0.0",
		"tiny-lru": "7.0.6"
	},
	"devDependencies": {
		"@automattic/jetpack-webpack-config": "workspace:*",
		"@babel/core": "7.29.7",
		"@babel/runtime": "7.29.7",
		"@size-limit/file": "^12.1.0",
		"@testing-library/dom": "10.4.1",
		"@testing-library/preact": "3.2.4",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "18.3.28",
		"@wordpress/browserslist-config": "6.50.0",
		"@wordpress/dependency-extraction-webpack-plugin": "6.50.0",
		"autoprefixer": "10.4.20",
		"babel-jest": "30.4.1",
		"babel-plugin-polyfill-corejs3": "0.14.0",
		"concurrently": "10.0.3",
		"core-js": "3.38.1",
		"jest": "30.4.2",
		"postcss": "8.5.14",
		"postcss-loader": "8.2.0",
		"sass-embedded": "1.97.3",
		"sass-loader": "16.0.5",
		"size-limit": "12.1.0",
		"storybook": "10.4.6",
		"webpack": "5.107.2",
		"webpack-cli": "6.0.1"
	}
}
