@top lines { line+ }

line { Date " " Time " " level " " Message newline }

Date { year "/" month "/" day }
year { d d d d }
month { d d }
day { d d }

Time { hour ":" minute ":" second }
hour { d d }
minute { d d }
second { d d }

level {
    Debug { "DEBUG" } |
    Info { "INFO" } |
    Warning { "WARNING" } |
    Error { "ERROR" } |
    Critical { "CRITICAL" }
}

Message { noNewline+ }

@tokens {
    d { @digit }
    newline { $[\u{000A}] }
    noNewline { ![\u{000A}] }
}