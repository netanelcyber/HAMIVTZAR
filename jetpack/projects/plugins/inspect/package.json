{
	"name": "@automattic/jetpack-inspect",
	"version": "2.0.0-a.11",
	"private": true,
	"description": "A debugging plugin to inspect Jetpack interactions with WordPress.com.",
	"homepage": "https://jetpack.com",
	"bugs": {
		"url": "https://github.com/Automattic/jetpack/labels/[Plugin] Inspect"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Automattic/jetpack.git",
		"directory": "projects/plugins/inspect"
	},
	"license": "GPL-2.0-or-later",
	"author": "Automattic",
	"type": "module",
	"scripts": {
		"build": "pnpm build-js",
		"build-js": "rollup -c rollup.config.js",
		"build-production": "pnpm build-production-js",
		"build-production-js": "rollup -c rollup.config.js",
		"clean": "rm -rf app-ui/build/",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@automattic/jetpack-webpack-config": "workspace:*",
		"@babel/core": "7.29.7",
		"@rollup/plugin-commonjs": "26.0.1",
		"@rollup/plugin-node-resolve": "15.3.0",
		"@rollup/plugin-terser": "1.0.0",
		"@rollup/plugin-typescript": "12.1.0",
		"@typescript/native-preview": "7.0.0-dev.20260225.1",
		"@wordpress/i18n": "6.23.0",
		"postcss": "8.5.14",
		"rollup": "3.30.0",
		"rollup-plugin-livereload": "2.0.5",
		"rollup-plugin-postcss": "4.0.2",
		"rollup-plugin-svelte": "7.2.2",
		"sass": "npm:sass-embedded@^1.97.2",
		"svelte": "5.55.7",
		"svelte-preprocess": "6.0.2",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"zod": "3.25.76"
	}
}
