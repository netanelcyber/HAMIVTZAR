{
	"name": "automattic/jetpack-shared-stores",
	"description": "Shared WordPress data stores used by the Jetpack block editor extensions, externalized into a single bundle to avoid duplicate store registration.",
	"type": "library",
	"license": "GPL-2.0-or-later",
	"require": {},
	"scripts": {
		"test-js": "pnpm run test",
		"test-js-coverage": "pnpm run test-coverage"
	},
	"repositories": [
		{
			"type": "path",
			"url": "../../packages/*",
			"options": {
				"monorepo": true
			}
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"autotagger": true,
		"npmjs-autopublish": true,
		"mirror-repo": "Automattic/jetpack-shared-stores",
		"textdomain": "jetpack-shared-stores",
		"changelogger": {
			"link-template": "https://github.com/Automattic/jetpack-shared-stores/compare/v${old}...v${new}"
		}
	}
}
