	"bugs": {
		"url": "https://github.com/Automattic/jetpack/labels/[JS Package] Jetpack Shared Stores"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Automattic/jetpack-shared-stores.git"
	},
	"license": "GPL-2.0-or-later",
	"author": "Automattic",
	"sideEffects": true,
	"exports": {
		".": "./index.js"
	},
	"scripts": {
		"test": "jest",
		"test-coverage": "pnpm run test --coverage",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@automattic/jetpack-script-data": "workspace:*",
		"@wordpress/api-fetch": "7.50.0",
		"@wordpress/data": "10.50.0"
	},
	"devDependencies": {
		"@automattic/jetpack-webpack-config": "workspace:*",
		"@babel/core": "7.29.7",
		"@babel/runtime": "7.29.7",
		"@types/jest": "30.0.0",
		"@types/react": "18.3.28",
		"@typescript/native-preview": "7.0.0-dev.20260707.2",
		"babel-jest": "30.4.1",
		"jest": "30.4.2",
		"jetpack-js-tools": "workspace:*",
		"react": "18.3.1"
	}
}
