{
	"name": "automattic/social-previews",
	"description": "A suite of components to generate previews for a post for both social and search engines.",
	"type": "library",
	"license": "GPL-2.0-or-later",
	"require": {},
	"scripts": {
		"build-development": [
			"pnpm run build"
		],
		"build-production": [
			"NODE_ENV=production pnpm run build"
		],
		"test-js": "pnpm run test",
		"test-js-coverage": "pnpm run test-coverage"
	},
	"repositories": [
		{
			"type": "path",
			"url": "../../packages/*",
			"options": {
				"monorepo": true
			}
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"autorelease": true,
		"autotagger": true,
		"npmjs-autopublish": true,
		"textdomain": "social-previews",
		"changelogger": {
			"link-template": "https://github.com/Automattic/social-previews/compare/v${old}...v${new}"
		},
		"mirror-repo": "Automattic/social-previews"
	}
}
