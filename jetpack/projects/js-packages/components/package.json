{
	"name": "@automattic/jetpack-components",
	"version": "1.12.15",
	"description": "Jetpack Components Package",
	"homepage": "https://github.com/Automattic/jetpack/tree/HEAD/projects/js-packages/components/#readme",
	"bugs": {
		"url": "https://github.com/Automattic/jetpack/labels/[JS Package] Components"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Automattic/jetpack-components.git"
	},
	"license": "GPL-2.0-or-later",
	"author": "Automattic",
	"sideEffects": [
		"*.css",
		"*.scss"
	],
	"type": "module",
	"exports": {
		".": {
			"jetpack:src": "./index.ts",
			"types": "./build/index.d.ts",
			"default": "./build/index.js"
		},
		"./admin-page": {
			"jetpack:src": "./components/admin-page/index.tsx",
			"types": "./build/components/admin-page/index.d.ts",
			"default": "./build/components/admin-page/index.js"
		},
		"./button": {
			"jetpack:src": "./components/button/index.tsx",
			"types": "./build/components/button/index.d.ts",
			"default": "./build/components/button/index.js"
		},
		"./global-notices": {
			"jetpack:src": "./components/global-notices/index.ts",
			"types": "./build/components/global-notices/index.d.ts",
			"default": "./build/components/global-notices/index.js"
		},
		"./gravatar": {
			"jetpack:src": "./components/gravatar/index.tsx",
			"types": "./build/components/gravatar/index.d.ts",
			"default": "./build/components/gravatar/index.js"
		},
		"./jetpack-footer": {
			"jetpack:src": "./components/jetpack-footer/index.tsx",
			"types": "./build/components/jetpack-footer/index.d.ts",
			"default": "./build/components/jetpack-footer/index.js"
		},
		"./jetpack-logo": {
			"jetpack:src": "./components/jetpack-logo/index.tsx",
			"types": "./build/components/jetpack-logo/index.d.ts",
			"default": "./build/components/jetpack-logo/index.js"
		},
		"./pricing-table": {
			"jetpack:src": "./components/pricing-table/index.tsx",
			"types": "./build/components/pricing-table/index.d.ts",
			"default": "./build/components/pricing-table/index.js"
		},
		"./product-price": {
			"jetpack:src": "./components/product-price/index.tsx",
			"types": "./build/components/product-price/index.d.ts",
			"default": "./build/components/product-price/index.js"
		},
		"./tools/jp-redirect": {
			"jetpack:src": "./tools/jp-redirect/index.ts",
			"types": "./build/tools/jp-redirect/index.d.ts",
			"default": "./build/tools/jp-redirect/index.js"
		}
	},
	"scripts": {
		"build": "pnpm run clean && pnpm run compile-ts && pnpm run copy-scss",
		"clean": "rm -rf build/",
		"compile-ts": "tsgo --pretty --project tsconfig.build.json",
		"copy-scss": "node ./tools/copy-scss-to-build.mjs",
		"test": "NODE_OPTIONS=--experimental-vm-modules jest",
		"test-coverage": "pnpm run test --coverage",
		"typecheck": "tsgo --noEmit"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"dependencies": {
		"@automattic/format-currency": "1.0.1",
		"@automattic/jetpack-api": "workspace:*",
		"@automattic/jetpack-boost-score-api": "workspace:*",
		"@automattic/jetpack-script-data": "workspace:*",
		"@automattic/number-formatters": "workspace:*",
		"@babel/runtime": "^7",
		"@gravatar-com/hovercards": "0.16.0",
		"@wordpress/admin-ui": "2.5.0",
		"@wordpress/browserslist-config": "6.50.0",
		"@wordpress/components": "36.1.0",
		"@wordpress/compose": "8.3.0",
		"@wordpress/data": "10.50.0",
		"@wordpress/date": "5.50.0",
		"@wordpress/element": "8.2.0",
		"@wordpress/i18n": "6.23.0",
		"@wordpress/icons": "15.1.0",
		"@wordpress/notices": "5.50.0",
		"@wordpress/theme": "0.17.0",
		"@wordpress/ui": "0.17.0",
		"clsx": "2.1.1",
		"js-sha256": "0.11.1",
		"prop-types": "^15.7.2",
		"qrcode.react": "4.2.0",
		"react-slider": "2.0.5",
		"social-logos": "workspace:*",
		"uplot": "1.6.31",
		"uplot-react": "1.1.4"
	},
	"devDependencies": {
		"@automattic/jetpack-base-styles": "workspace:*",
		"@babel/core": "7.29.7",
		"@jest/globals": "30.4.1",
		"@storybook/addon-docs": "10.4.6",
		"@storybook/react": "10.4.6",
		"@testing-library/dom": "10.4.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/jest": "30.0.0",
		"@types/react": "18.3.28",
		"@types/react-dom": "18.3.7",
		"@types/react-slider": "1.3.6",
		"@typescript/native-preview": "7.0.0-dev.20260225.1",
		"jest": "30.4.2",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"require-from-string": "2.0.2",
		"storybook": "10.4.6",
		"ts-dedent": "2.2.0",
		"typescript": "5.9.3",
		"webpack": "5.107.2",
		"webpack-cli": "6.0.1"
	},
	"peerDependencies": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0"
	}
}
