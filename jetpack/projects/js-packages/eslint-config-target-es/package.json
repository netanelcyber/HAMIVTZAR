		"semver": "^7.3.5"
	},
	"devDependencies": {
		"@wordpress/browserslist-config": "6.50.0",
		"eslint": "10.6.0",
		"eslint-plugin-es-x": "9.7.0",
		"globals": "16.5.0",
		"jest": "30.4.2"
	},
	"peerDependencies": {
		"eslint": ">=4.19.1",
		"eslint-plugin-es-x": "^8.0.0 || ^9.0.0",
