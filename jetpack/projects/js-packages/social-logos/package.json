{
	"name": "social-logos",
	"version": "3.3.16",
	"description": "A repository of all the social logos used on WordPress.com.",
	"homepage": "https://github.com/Automattic/jetpack/tree/HEAD/projects/js-packages/social-logos/",
	"author": "Automattic",
	"bugs": {
		"url": "https://github.com/Automattic/jetpack/labels/[JS Package] Social Logos"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Automattic/social-logos.git"
	},
	"license": "GPL-2.0+",
	"exports": {
		".": {
			"jetpack:src": "./src/react/index.ts",
			"default": "./build/react/index.js"
		},
		"./colors.css": "./src/social-logo-colors.css",
		"./font/*": {
			"default": "./build/font/*"
		},
		"./svg-sprite/*": {
			"default": "./build/svg-sprite/social-logos.svg"
		}
	},
	"main": "build/react/index.js",
	"types": "build/react/index.d.ts",
	"scripts": {
		"build": "./tools/build",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"prop-types": "^15.8.1"
	},
	"devDependencies": {
		"@types/react": "18.3.28",
		"@types/react-dom": "18.3.7",
		"@typescript/native-preview": "7.0.0-dev.20260225.1",
		"glob": "13.0.6",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"svg2ttf": "^6.0.3",
		"svgicons2svgfont": "^15.0.0",
		"svgo": "^4.0.0",
		"svgstore": "^3.0.1",
		"wawoff2": "^2.0.1",
		"xml2js": "^0.6.2"
	},
	"peerDependencies": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0"
	}
}
