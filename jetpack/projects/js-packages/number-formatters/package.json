{
	"name": "@automattic/number-formatters",
	"version": "1.2.5",
	"description": "Number formatting utilities",
	"homepage": "https://github.com/Automattic/jetpack/tree/HEAD/projects/js-packages/number-formatters/#readme",
	"bugs": {
		"url": "https://github.com/Automattic/jetpack/labels/[JS Package] Number Formatters"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Automattic/number-formatters.git"
	},
	"license": "GPL-2.0-or-later",
	"author": "Automattic",
	"type": "module",
	"exports": {
		".": {
			"jetpack:src": "./src/index.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "pnpm run clean && pnpm run build:ts",
		"build:ts": "tsdown",
		"clean": "rm -rf dist",
		"test": "NODE_OPTIONS=--experimental-vm-modules jest",
		"test-coverage": "pnpm run test --coverage",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@wordpress/date": "^5.19.0",
		"debug": "^4.4.0"
	},
	"devDependencies": {
		"@babel/core": "7.29.7",
		"@jest/globals": "30.4.1",
		"@types/jest": "30.0.0",
		"@typescript/native-preview": "7.0.0-dev.20260707.2",
		"jest": "30.4.2",
		"jetpack-js-tools": "workspace:*",
		"tsdown": "0.22.2",
		"typescript": "6.0.3"
	}
}
