{
	"name": "@automattic/eslint-changed",
	"version": "2.1.6",
	"description": "Run eslint on files, but only report warnings and errors from lines that were changed.",
	"keywords": [
		"eslint",
		"changed"
	],
	"homepage": "https://github.com/Automattic/jetpack/tree/HEAD/projects/js-packages/eslint-changed/#readme",
	"bugs": {
		"url": "https://github.com/Automattic/jetpack/labels/[JS Package] Eslint Changed"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Automattic/eslint-changed.git"
	},
	"license": "GPL-2.0-or-later",
	"author": "Automattic",
	"type": "module",
	"bin": {
		"eslint-changed": "bin/eslint-changed.js"
	},
	"exports": {
		"./package.json": "./package.json"
	},
	"scripts": {
		"test": "NODE_OPTIONS=--experimental-vm-modules jest --config=tests/jest.config.cjs",
		"test-coverage": "pnpm run test --coverage"
	},
	"dependencies": {
		"chalk": "5.6.2",
		"commander": "13.0.0",
		"parse-diff": "0.8.1"
	},
	"devDependencies": {
		"eslint": ">=7.0.0",
		"jest": "30.4.2"
	},
	"peerDependencies": {
		"eslint": ">=7.0.0"
	}
}
